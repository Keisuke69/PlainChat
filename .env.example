# PlainChat 環境変数のサンプル。
# このファイルを `.env` にコピーして値を埋めてください:  cp .env.example .env
# （DevContainer 利用時は scripts/setup-env.mjs が .env を自動生成するため、本ファイルの操作は不要です）

# SQLite データベースの場所（通常は変更不要）
DATABASE_URL="file:./dev.db"

# Better Auth のセッション署名用シークレット（ランダムな長い文字列に変更すること）
#   生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET="change-me-to-a-random-32-byte-hex"

# アプリの公開 URL（ローカル開発では通常このまま）
BETTER_AUTH_URL="http://localhost:3000"

# API キーの暗号化用キー（AES-256-GCM、ランダムな長い文字列に変更すること）
#   生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="change-me-to-a-random-32-byte-hex"
